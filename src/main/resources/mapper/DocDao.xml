<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="wanghui.airagproject.dao.DocDao">

    <insert id="insert" parameterType="wanghui.airagproject.pojo.Doc">
        INSERT INTO doc_chunk(content, embedding, create_time)
        VALUES (#{content}, #{embedding}, now())
    </insert>
    <select id="selectAll" resultType="wanghui.airagproject.pojo.Doc">
        SELECT id, content, embedding
        FROM doc_chunk
    </select>

</mapper>